rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserProfile() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isPlatformAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/platformAdmins/$(request.auth.uid))
        && get(/databases/$(database)/documents/platformAdmins/$(request.auth.uid)).data.status == "active";
    }

    function sameCompany(companyId) {
      return hasUserProfile()
        && currentUser().data.companyId == companyId
        && currentUser().data.status == "active";
    }

    function role() {
      return currentUser().data.role;
    }

    function ownerOrAdmin() {
      return hasUserProfile() && role() in ["owner", "admin"];
    }

    function ownerOnly() {
      return hasUserProfile() && role() == "owner";
    }

    function companyFromResource() {
      return resource.data.companyId;
    }

    function companyFromRequest() {
      return request.resource.data.companyId;
    }

    match /companies/{companyId} {
      allow read: if isPlatformAdmin() || sameCompany(companyId);
      allow create: if isPlatformAdmin() || (signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.status == "active");
      allow update: if isPlatformAdmin() || (sameCompany(companyId) && ownerOnly());
      allow delete: if false;
    }

    match /users/{userId} {
      allow read: if isPlatformAdmin() || (hasUserProfile() && sameCompany(resource.data.companyId));
      allow create: if isPlatformAdmin() || (signedIn()
        && (
          userId == request.auth.uid
          || (ownerOrAdmin() && sameCompany(companyFromRequest()))
        ));
      allow update: if isPlatformAdmin() || (hasUserProfile()
        && sameCompany(companyFromResource())
        && (
          userId == request.auth.uid
          || ownerOrAdmin()
        )
        && request.resource.data.companyId == resource.data.companyId);
      allow delete: if false;
    }

    match /subscriptions/{subscriptionId} {
      allow read: if isPlatformAdmin() || (hasUserProfile()
        && exists(/databases/$(database)/documents/companies/$(currentUser().data.companyId))
        && get(/databases/$(database)/documents/companies/$(currentUser().data.companyId)).data.subscriptionId == subscriptionId);
      allow create: if isPlatformAdmin();
      allow update: if isPlatformAdmin() || (ownerOnly()
        && exists(/databases/$(database)/documents/companies/$(currentUser().data.companyId))
        && get(/databases/$(database)/documents/companies/$(currentUser().data.companyId)).data.subscriptionId == subscriptionId);
      allow delete: if false;
    }

    match /roles/{roleId} {
      allow read: if isPlatformAdmin() || sameCompany(resource.data.companyId);
      allow create: if isPlatformAdmin() || (ownerOrAdmin() && sameCompany(companyFromRequest()));
      allow update: if isPlatformAdmin() || (ownerOrAdmin()
        && sameCompany(companyFromResource())
        && request.resource.data.companyId == resource.data.companyId);
      allow delete: if isPlatformAdmin() || (ownerOnly() && sameCompany(companyFromResource()));
    }

    match /permissions/{permissionId} {
      allow read: if isPlatformAdmin() || hasUserProfile();
      allow write: if isPlatformAdmin();
    }

    match /activityLogs/{logId} {
      allow read: if isPlatformAdmin() || sameCompany(resource.data.companyId);
      allow create: if isPlatformAdmin() || (hasUserProfile() && sameCompany(companyFromRequest()));
      allow update, delete: if false;
    }

    match /platformAdmins/{adminId} {
      allow read: if signedIn() && adminId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
