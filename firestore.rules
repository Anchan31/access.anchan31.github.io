rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAccessPortalOwner() {
      return isSignedIn() &&
        request.auth.token.email in [
          'nextgenudaan@gmail.com',
          'it.nextgenudaan@gmail.com'
        ];
    }

    function platformAdminPath() {
      return /databases/$(database)/documents/platformAdmins/$(request.auth.uid);
    }

    function isPlatformAdmin() {
      return isSignedIn() &&
        exists(platformAdminPath()) &&
        get(platformAdminPath()).data.status == 'active' &&
        get(platformAdminPath()).data.role == 'owner';
    }

    function hasFullAccess() {
      return isAccessPortalOwner() || isPlatformAdmin();
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserData() {
      return isSignedIn() && exists(userPath());
    }

    function getUserData() {
      return get(userPath()).data;
    }

    function getUserCompanyId() {
      return getUserData().companyId;
    }

    function getUserRole() {
      return getUserData().role;
    }

    function isOwnerOrAdmin() {
      return hasUserData() &&
        (getUserRole() == 'owner' || getUserRole() == 'admin');
    }

    function isCompanyUser(companyId) {
      return hasUserData() && getUserCompanyId() == companyId;
    }

    function canManageCompany(companyId) {
      return hasFullAccess() ||
        (
          isCompanyUser(companyId) &&
          (getUserRole() == 'owner' || getUserRole() == 'admin')
        );
    }

    function canWorkInCompany(companyId) {
      return hasFullAccess() ||
        (
          isCompanyUser(companyId) &&
          getUserRole() != 'viewer'
        );
    }

    // --- ACCESS PORTAL ADMIN ---

    match /platformAdmins/{uid} {
      allow read: if isSignedIn() && (
        hasFullAccess() ||
        request.auth.uid == uid
      );

      allow create, update: if isSignedIn() && (
        hasFullAccess() ||
        (
          request.auth.uid == uid &&
          isAccessPortalOwner() &&
          request.resource.data.email == request.auth.token.email &&
          request.resource.data.role == 'owner' &&
          request.resource.data.status == 'active'
        )
      );

      allow delete: if hasFullAccess();
    }

    match /subscriptions/{id} {
      allow read, create, update, delete: if hasFullAccess();
    }

    match /accessPasses/{id} {
      allow read, create, update, delete: if hasFullAccess();
    }

    match /roles/{id} {
      allow read, create, update, delete: if hasFullAccess();
    }

    match /permissions/{id} {
      allow read, create, update, delete: if hasFullAccess();
    }

    match /activityLogs/{id} {
      allow read, create, update, delete: if hasFullAccess();
    }

    match /purchaseRequests/{id} {
      allow read, create, update, delete: if hasFullAccess();
    }

    // --- SETTINGS ---

    match /settings/{docId} {
      allow read: if true;

      allow write: if isSignedIn() && (
        hasFullAccess() ||
        (
          isOwnerOrAdmin() &&
          (
            docId == 'publicPortal' ||
            docId == 'publicPortal_' + getUserCompanyId()
          )
        )
      );
    }

    // --- COMPANIES ---

    match /companies/{companyId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn() && (
        hasFullAccess() ||
        isOwnerOrAdmin()
      );
    }

    // --- USERS ---

    match /users/{uid} {
      allow read: if isSignedIn() && (
        hasFullAccess() ||
        request.auth.uid == uid ||
        (
          hasUserData() &&
          getUserCompanyId() == resource.data.companyId
        )
      );

      allow create: if isSignedIn() && (
        hasFullAccess() ||
        request.auth.uid == uid
      );

      allow update: if isSignedIn() && (
        hasFullAccess() ||
        request.auth.uid == uid ||
        canManageCompany(resource.data.companyId)
      );

      allow delete: if isSignedIn() && (
        hasFullAccess() ||
        canManageCompany(resource.data.companyId)
      );
    }

    // --- JOBS ---

    match /jobs/{jobId} {
      allow read: if resource.data.status == 'Open' ||
        hasFullAccess() ||
        (
          isSignedIn() &&
          hasUserData() &&
          getUserCompanyId() == resource.data.companyId
        );

      allow create: if isSignedIn() &&
        canWorkInCompany(request.resource.data.companyId);

      allow update, delete: if isSignedIn() &&
        canWorkInCompany(resource.data.companyId);
    }

    // --- CANDIDATES ---

    match /candidates/{candidateId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isSignedIn() &&
        canWorkInCompany(resource.data.companyId);
    }

    // --- INTERVIEWS ---

    match /interviews/{id} {
      allow read: if isSignedIn() && (
        hasFullAccess() ||
        isCompanyUser(resource.data.companyId)
      );

      allow create: if isSignedIn() &&
        canWorkInCompany(request.resource.data.companyId);

      allow update, delete: if isSignedIn() &&
        canWorkInCompany(resource.data.companyId);
    }

    // --- OFFERS ---

    match /offers/{id} {
      allow read: if isSignedIn() && (
        hasFullAccess() ||
        isCompanyUser(resource.data.companyId)
      );

      allow create: if isSignedIn() &&
        canWorkInCompany(request.resource.data.companyId);

      allow update, delete: if isSignedIn() &&
        canWorkInCompany(resource.data.companyId);
    }

    // --- OFFER TEMPLATES ---

    match /offerTemplates/{id} {
      allow read: if isSignedIn() && (
        hasFullAccess() ||
        isCompanyUser(resource.data.companyId)
      );

      allow create: if isSignedIn() &&
        canManageCompany(request.resource.data.companyId);

      allow update, delete: if isSignedIn() &&
        canManageCompany(resource.data.companyId);
    }

    // --- WHATSAPP TEMPLATES ---

    match /whatsappTemplates/{id} {
      allow read: if isSignedIn() && (
        hasFullAccess() ||
        isCompanyUser(resource.data.companyId)
      );

      allow create: if isSignedIn() &&
        canManageCompany(request.resource.data.companyId);

      allow update, delete: if isSignedIn() &&
        canManageCompany(resource.data.companyId);
    }

    // --- PRESENCE ---

    match /presence/{id} {
      allow read: if isSignedIn() && (
        hasFullAccess() ||
        isCompanyUser(resource.data.companyId)
      );

      allow create: if isSignedIn() && (
        hasFullAccess() ||
        isCompanyUser(request.resource.data.companyId)
      );

      allow update, delete: if isSignedIn() && (
        hasFullAccess() ||
        isCompanyUser(resource.data.companyId)
      );
    }

    // --- AUDIT LOGS ---

    match /audit_logs/{id} {
      allow read: if isSignedIn() && (
        hasFullAccess() ||
        canManageCompany(resource.data.companyId)
      );

      allow create: if isSignedIn() && (
        hasFullAccess() ||
        isCompanyUser(request.resource.data.companyId)
      );

      allow update, delete: if hasFullAccess();
    }

    // --- MASTER DATA ---

    match /masters_departments/{id} {
      allow read: if isSignedIn() && (
        hasFullAccess() ||
        isCompanyUser(resource.data.companyId)
      );

      allow create: if isSignedIn() &&
        canWorkInCompany(request.resource.data.companyId);

      allow update, delete: if isSignedIn() &&
        canWorkInCompany(resource.data.companyId);
    }

    match /masters_designations/{id} {
      allow read: if isSignedIn() && (
        hasFullAccess() ||
        isCompanyUser(resource.data.companyId)
      );

      allow create: if isSignedIn() &&
        canWorkInCompany(request.resource.data.companyId);

      allow update, delete: if isSignedIn() &&
        canWorkInCompany(resource.data.companyId);
    }

    match /masters_industries/{id} {
      allow read: if isSignedIn() && (
        hasFullAccess() ||
        isCompanyUser(resource.data.companyId)
      );

      allow create: if isSignedIn() &&
        canWorkInCompany(request.resource.data.companyId);

      allow update, delete: if isSignedIn() &&
        canWorkInCompany(resource.data.companyId);
    }

    match /masters_sources/{id} {
      allow read: if isSignedIn() && (
        hasFullAccess() ||
        isCompanyUser(resource.data.companyId)
      );

      allow create: if isSignedIn() &&
        canWorkInCompany(request.resource.data.companyId);

      allow update, delete: if isSignedIn() &&
        canWorkInCompany(resource.data.companyId);
    }

    // --- FULL ACCESS PORTAL OWNER CONTROL ---
    // The two main access portal emails can view, create, edit, and delete every document.

    match /{document=**} {
      allow read, create, update, delete: if isAccessPortalOwner();
    }

    // --- DEFAULT DENY ---

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
